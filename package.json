    "llm",
    "llm-orchestration",
    "machine-learning",
    "mcp",
    "mcp-server",
    "mcp-tools",
    "memory-persistence",
    "mesh-network",
    "multi-agent",
    "multi-agent-systems",
    "neural-networks",
    "onnx",
    "onnxruntime",
    "orchestration",
    "pagerank",
    "parallel-processing",
    "quic",
    "raft",
    "tafy",
    "tafyai",
    "sparc",
    "sublinear-algorithms",
    "swarm",
    "swarm-intelligence",
    "task-orchestration",
    "typescript",
    "workflow",
    "workflow-automation"
