# Centralized Configuration - Environment Variables
# Copy this file to .env and configure your settings

# ================================
# Embedding Configuration
# ================================
EMBEDDING_PROVIDER=hash                    # Options: openai, anthropic, hash
EMBEDDING_DIMENSIONS=384                   # Embedding vector dimensions
EMBEDDING_MODEL=text-embedding-ada-002     # Model name for embeddings

# ================================
# PII Scrubbing Configuration
# ================================
PII_SCRUBBING_ENABLED=true                 # Enable/disable PII scrubbing
PII_SCRUB_EMAIL=true                       # Scrub email addresses
PII_SCRUB_SSN=true                         # Scrub Social Security Numbers
PII_SCRUB_API_KEY=true                     # Scrub API keys
PII_SCRUB_CREDIT_CARD=true                 # Scrub credit card numbers
PII_SCRUB_PHONE=true                       # Scrub phone numbers
PII_SCRUB_IP_ADDRESS=true                  # Scrub IP addresses
PII_SCRUB_BEARER_TOKEN=true                # Scrub bearer tokens
PII_SCRUB_PRIVATE_KEY=true                 # Scrub private keys

# ================================
# OpenAI API Configuration
# ================================
OPENAI_API_KEY=                            # Your OpenAI API key
OPENAI_BASE_URL=https://api.openai.com/v1 # OpenAI API base URL
OPENAI_TIMEOUT=30000                       # Request timeout in milliseconds
OPENAI_MAX_RETRIES=3                       # Maximum retry attempts
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002  # OpenAI embedding model

# ================================
# Anthropic API Configuration
# ================================
ANTHROPIC_API_KEY=                         # Your Anthropic API key
ANTHROPIC_BASE_URL=https://api.anthropic.com  # Anthropic API base URL
ANTHROPIC_TIMEOUT=30000                    # Request timeout in milliseconds
ANTHROPIC_MAX_RETRIES=3                    # Maximum retry attempts
ANTHROPIC_EMBEDDING_MODEL=claude-3-haiku   # Anthropic embedding model

# ================================
# Model Configuration
# ================================
DEFAULT_MODEL=hash                         # Default model to use

# ================================
# ONNX Configuration
# ================================
ONNX_ENABLED=false                         # Enable ONNX runtime
ONNX_MODEL_PATH=                           # Path to ONNX model file
ONNX_EXECUTION_PROVIDERS=cpu               # Comma-separated list: cpu,cuda,directml

# ================================
# Feature Flags
# ================================
FEATURE_CACHING=true                       # Enable result caching
FEATURE_METRICS=true                       # Enable metrics collection
FEATURE_LOGGING=true                       # Enable logging
FEATURE_DEBUG=false                        # Enable debug mode

# ================================
# Performance Configuration
# ================================
MAX_CONCURRENT_REQUESTS=10                 # Maximum concurrent API requests
REQUEST_TIMEOUT=60000                      # Global request timeout (ms)
CACHE_SIZE=1000                            # Maximum cache entries
CACHE_TTL=3600000                          # Cache time-to-live (ms)

# ================================
# Database Configuration
# ================================
DB_PATH=./data/reasoningbank.db           # Database file path
DB_MAX_CONNECTIONS=5                       # Maximum database connections
DB_TIMEOUT=5000                            # Database operation timeout (ms)
