{
  "name": "@agent-control-plane/contract-tests",
  "version": "1.10.3",
  "description": "Contract tests for Agentic Flow MCP tools and APIs",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:mcp": "jest mcp-contracts.test.ts",
    "test:api": "jest api-contracts.test.ts",
    "test:service": "jest service-contracts.test.ts",
    "contracts:generate": "tsx contract-generator.ts",
    "contracts:validate": "node validate-contracts.js",
    "contracts:coverage": "node coverage-report.js",
    "schemas:validate": "ajv validate -s schemas/*.schema.json",
    "pact:publish": "pact-broker publish pacts --consumer-app-version=$npm_package_version",
    "pact:verify": "pact-broker can-i-deploy --pacticipant agent-control-plane --version $npm_package_version"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@pact-foundation/pact": "^12.1.0",
    "@types/jest": "^29.5.11",
    "ajv": "^8.12.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.6.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "**/*.test.ts",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
