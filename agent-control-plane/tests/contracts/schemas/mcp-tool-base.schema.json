{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-control-plane.io/schemas/mcp-tool-base.json",
  "title": "MCP Tool Base Schema",
  "description": "Base schema for all MCP tool interfaces",
  "type": "object",
  "required": ["name", "description", "inputSchema"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z_][a-z0-9_]*$",
      "description": "Tool name in snake_case"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Tool description"
    },
    "inputSchema": {
      "type": "object",
      "description": "JSON Schema for input parameters",
      "required": ["type", "properties"],
      "properties": {
        "type": {
          "const": "object"
        },
        "properties": {
          "type": "object"
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "outputSchema": {
      "type": "object",
      "description": "JSON Schema for output format",
      "properties": {
        "type": {
          "type": "string"
        },
        "properties": {
          "type": "object"
        }
      }
    },
    "errorSchema": {
      "type": "object",
      "description": "JSON Schema for error responses",
      "properties": {
        "type": {
          "const": "object"
        },
        "properties": {
          "type": "object",
          "required": ["error", "message"],
          "properties": {
            "error": {
              "type": "object"
            },
            "message": {
              "type": "object"
            }
          }
        }
      }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "auth": {
      "type": "object",
      "properties": {
        "required": {
          "type": "boolean"
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
