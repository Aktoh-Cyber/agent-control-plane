{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-control-plane.io/schemas/swarm-tools.json",
  "title": "Swarm Management Tools Schema",
  "description": "Contract schemas for swarm coordination tools",
  "definitions": {
    "swarmInitInput": {
      "type": "object",
      "required": ["topology"],
      "properties": {
        "topology": {
          "type": "string",
          "enum": ["mesh", "hierarchical", "ring", "star"]
        },
        "maxAgents": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 8
        },
        "strategy": {
          "type": "string",
          "enum": ["balanced", "specialized", "adaptive"],
          "default": "balanced"
        }
      }
    },
    "swarmInitOutput": {
      "type": "object",
      "required": ["success", "topology", "maxAgents", "timestamp"],
      "properties": {
        "success": {
          "type": "boolean"
        },
        "topology": {
          "type": "string"
        },
        "maxAgents": {
          "type": "integer"
        },
        "strategy": {
          "type": "string"
        },
        "swarmId": {
          "type": "string",
          "format": "uuid"
        },
        "result": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "agentSpawnInput": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["researcher", "coder", "tester", "reviewer", "planner"]
        },
        "config": {
          "type": "object",
          "properties": {
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "maxTokens": {
              "type": "integer",
              "minimum": 100,
              "maximum": 4096
            }
          }
        }
      }
    },
    "agentSpawnOutput": {
      "type": "object",
      "required": ["success", "agentId", "type"],
      "properties": {
        "success": {
          "type": "boolean"
        },
        "agentId": {
          "type": "string",
          "format": "uuid"
        },
        "type": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["initializing", "ready", "busy", "error"]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "taskOrchestrateInput": {
      "type": "object",
      "required": ["tasks"],
      "properties": {
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "assignedAgent": {
                "type": "string"
              },
              "priority": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              }
            }
          }
        },
        "parallel": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "taskOrchestrateOutput": {
      "type": "object",
      "required": ["success", "taskCount", "orchestrationId"],
      "properties": {
        "success": {
          "type": "boolean"
        },
        "taskCount": {
          "type": "integer"
        },
        "orchestrationId": {
          "type": "string",
          "format": "uuid"
        },
        "assignedAgents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "estimatedDuration": {
          "type": "integer",
          "description": "Estimated duration in seconds"
        }
      }
    },
    "errorResponse": {
      "type": "object",
      "required": ["error", "message"],
      "properties": {
        "error": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "details": {
          "type": "object"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
