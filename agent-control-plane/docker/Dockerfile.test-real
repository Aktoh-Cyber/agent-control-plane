FROM node:22-slim

WORKDIR /app

# Copy local package
COPY agent-control-plane/package.json ./
COPY agent-control-plane/dist ./dist
COPY agent-control-plane/.claude ./.claude
COPY agent-control-plane/docs ./docs

# Copy .env from root
COPY .env ./.env

# Install dependencies and link globally
RUN npm install --omit=dev && npm link

# Set up environment
ENV NODE_ENV=production

# Test command
CMD ["agent-control-plane", "--agent", "coder", "--task", "Write a simple hello world function in Python"]
