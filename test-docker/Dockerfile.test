FROM node:20-slim

# Avoid interactive tzdata prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install minimal dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install agent-control-plane from local build
COPY ./agent-control-plane/package.json ./agent-control-plane/
COPY ./agent-control-plane/dist ./agent-control-plane/dist
COPY ./agent-control-plane/wasm ./agent-control-plane/wasm
COPY ./agent-control-plane/config ./agent-control-plane/config
COPY ./agent-control-plane/.claude ./agent-control-plane/.claude
COPY ./package.json ./
COPY ./package-lock.json* ./

# Install dependencies
RUN npm ci --no-audit --no-fund || npm install --no-audit --no-fund

# Runtime env
ENV NODE_ENV=production
ENV ANTHROPIC_API_KEY=""
ENV OPENROUTER_API_KEY=""

# Create writable workspace
RUN mkdir -p /workspace && chmod 777 /workspace
WORKDIR /workspace

# Test entry point
ENTRYPOINT ["npx", "agent-control-plane"]
CMD ["--help"]
