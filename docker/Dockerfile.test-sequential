FROM node:22-slim
WORKDIR /app

# Copy local built package
COPY agent-control-plane/package.json ./
COPY agent-control-plane/dist ./dist
COPY agent-control-plane/.claude ./.claude

# Copy .env
COPY .env ./.env

# Install and link
RUN npm install --omit=dev && npm link

ENV NODE_ENV=production

# Default: test Anthropic (fastest)
CMD ["agent-control-plane", "--agent", "coder", "--task", "Write hello world", "--provider", "anthropic"]
